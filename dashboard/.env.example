# Copy to .env for local runs (or set these as Railway variables).
# Connection details come from the SQL Warehouse → "Connection details" tab.

DATABRICKS_SERVER_HOSTNAME=adb-xxxxxxxxxxxx.x.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx

# Read-only OAuth service principal (grant it SELECT on the gold/silver tables
# and CAN_USE on the SQL Warehouse).
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Unity Catalog to read from (schemas 02_silver / 03_gold are fixed).
DATABRICKS_CATALOG=citibike_ext_dev
