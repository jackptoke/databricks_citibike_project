# Copy to .env and fill in — used for local Databricks Connect / CLI auth.
# See https://docs.databricks.com/dev-tools/auth/oauth-m2m.html

# Workspace URL, e.g. https://adb-xxxx.az.databricks.net
DATABRICKS_HOST=

# OAuth service-principal (machine-to-machine) credentials
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Optional: serverless compute for Databricks Connect / pytest integration tests
# DATABRICKS_SERVERLESS_COMPUTE_ID=auto
